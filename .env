# 🧠 ANTIGRAVITY GATEWAY CONFIGURATION (.env.example)
# ----------------------------------------------------------

# [Hạ Tầng Telegram]
# Lấy token từ @BotFather
TELEGRAM_BOT_TOKEN="your_bot_token_here"

# ID người dùng được phép điều khiển (Bảo mật - Quan trọng!)
# Lấy ID qua @userinfobot
ALLOWED_USER_IDS="123456789,987654321"

# ID Chat/Group được phép hoạt động (Để tránh Bot bị kéo vào group lạ)
ALLOWED_CHAT_IDS="-100123456789"

# [Cấu Hình LSP & Remote]
# Cổng DeckServer của Antigravity LSP (Mặc định là 3500)
LSP_PORT=3500

# Đường dẫn Workspace cơ sở (Dùng cho lệnh /project của LazyGravity)
WORKSPACE_DIR="~/Projects"

# [Local AI - Ollama Dual-Brain]
# URL của Ollama server (Mặc định: http://localhost:11434)
OLLAMA_API_URL="http://localhost:11434"

# Cho phép vác tác vụ nặng xuống Local Model (True/False)
OLLAMA_DELEGATION_ENABLED=true

# Chân lý Định tuyến: 'local' hoặc 'cloud'
AGENT_MODEL_MODE=local

# Lõi Điều Phối (Nemotron-Orchestrator)
LOCAL_ORCHESTRATOR_MODEL="hf.co/mohusein/Nemotron-Orchestrator-8B-Claude-4.5-Opus-Distill-GGUF:iq4_nl"

# Thợ Code Siêu Tốc (Qwen Coder)
LOCAL_CODER_MODEL="hf.co/bartowski/Qwen2.5.1-Coder-7B-Instruct-GGUF:IQ4_XS"

# [Tùy Chọn Khác]
LOG_LEVEL="info"
AUTO_ACCEPT_ENABLED=true

PROJECT_NAME=ReaperAI_Karaoke

# [Audio Port Mapping]
# Cổng nhận nhạc nền (Browser/Chrome) và Vocal (Micro) trong REAPER.
# Mặc định hệ thống dùng in1/in2 cho Vocal và in3/in4 cho Nhạc nền.
# Nếu bạn thay đổi thứ tự cổng trong REAPER (ví dụ: dùng in1/in2 cho Nhạc nền và in3/in4 cho Vocal),
# hãy uncomment và điều chỉnh các giá trị dưới đây:
# REAPER_MUSIC_IN_L="REAPER:in1"
# REAPER_MUSIC_IN_R="REAPER:in2"
# REAPER_VOCAL_IN_L="REAPER:in3"
# REAPER_VOCAL_IN_R="REAPER:in4"
